VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Integration secrets (OAuth, APIs) are set in Supabase Edge Function secrets, not here.
# See docs/integrations/DEVELOPER_SETUP.md for the full checklist and secret names.

# MapKit JS (Market Intelligence area map). Requires Apple Developer account.
# Create a Maps identifier and private key, then set in Supabase Edge Function secrets:
#   APPLE_MAPKIT_TEAM_ID, APPLE_MAPKIT_KEY_ID, APPLE_MAPKIT_PRIVATE_KEY (PEM string)
# Deploy: supabase functions deploy mapkit-token

# OpenAI (server-side only — set in Vercel for production, or here for local dev)
# Do NOT use VITE_ prefix; the key must never be exposed to the client.
#
# Local dev: add OPENAI_API_KEY to your .env, then in one terminal run `npm run dev`,
# in another run `npm run dev:api`. The Vite dev server proxies /api to the local proxy.
#
# OPENAI_API_KEY=sk-...
